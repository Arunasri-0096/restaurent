</head>

<body>

<header>
<h1>Welcome to DevOps Restaurant</h1>
</header>

<div class="menu">

<div class="item">
<h2>Pizza</h2>
<p>Price : ₹250</p>
</div>

<div class="item">
<h2>Burger</h2>
<p>Price : ₹150</p>
</div>

<div class="item">
<h2>Biryani</h2>
<p>Price : ₹300</p>
</div>

</div>

</body>
</html>
